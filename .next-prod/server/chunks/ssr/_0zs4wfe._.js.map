[{"title":"Policing and Technology","description":"Bringing together debates from law, criminology, socio-legal studies and critical security studies to examine digital governance and policing in postcolonial contexts such as Pakistan."},{"title":"Cybercrime Laws and Enforcement","description":"A comparative study of how cybercrime statutes operate across South Asian and Southeast Asian jurisdictions, and what their enforcement means for the societies they govern."},{"title":"Police Pluralisation","description":"Collaborative research on security provision by diverse actors, including public, private, hybrid, state and non-state providers, in urban areas of the Global South. Funded by the BA-Leverhulme Small Grant Scheme and UCL's Centre for Global City Policing."},{"title":"Terrains of Disappearances","description":"A collaborative project building an international, multidisciplinary network of academics, artists and practitioners examining manifestations of disappearance, loss, grief and absence globally. Led by Professor Nichola Khan with AHRC support."},{"title":"Urban Violence and Insecurity","description":"Multiple collaborative projects examining urban violence, insecurity and governance in the Global South through interdisciplinary approaches."}]