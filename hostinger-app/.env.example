APP_NAME="Jubilee Water"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Hostinger shared hosting only offers MySQL (managed via phpMyAdmin in
# hPanel) — no Node.js, no SQLite persistence guarantees. Create the
# database + user in hPanel > Databases > MySQL Databases first, then fill
# these in with the values it gives you.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# File-based session/cache/queue — no Redis/Memcached on shared hosting.
SESSION_DRIVER=file
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# The admin login has no separate account record — this single shared
# password IS the admin role (see AuthController::login). Set a strong,
# unique value in production; there is no dev fallback when APP_ENV isn't
# "local".
ADMIN_PASSWORD=

# Comma-separated list of origins allowed to call this API (the deployed
# SPA's origin). "*" works but disallows credentialed requests — fine here
# since auth is a bearer token, not a cookie.
CORS_ALLOWED_ORIGINS=*

# Web Push VAPID keypair. These default to the same keypair the Cloudflare
# deployment shipped with (see config/services.php) — override both with
# your own keypair in production (generate via `php artisan tinker` +
# minishlink/web-push's VAPID::createVapidKeys(), or any VAPID key
# generator) and update the same public key in spa/src/lib/push-public-key.ts.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
