    },
    {
      "page": "/cv",
      "regex": "^/cv(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cv(?:/)?$"
    },
    {
      "page": "/icon.svg",
      "regex": "^/icon\\.svg(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.svg(?:/)?$"
    },
    {
      "page": "/in-progress",
      "regex": "^/in\\-progress(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/in\\-progress(?:/)?$"
    },
    {
      "page": "/llms.txt",
