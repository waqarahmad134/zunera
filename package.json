{
  "name": "zoha",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply zunera --local",
    "db:migrate": "wrangler d1 migrations apply zunera --remote",
    "db:seed:local": "node scripts/seed.mjs && wrangler d1 execute zunera --local --file=scripts/seed.sql",
    "db:seed": "node scripts/seed.mjs && wrangler d1 execute zunera --remote --file=scripts/seed.sql",
    "media:upload:local": "node scripts/upload-media.mjs --local",
    "media:upload": "node scripts/upload-media.mjs --remote"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.3.0",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.20.0"
  }
}
