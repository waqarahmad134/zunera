[{"title":"Insecure Guardians: Enforcement, Encounters and Everyday Policing in Postcolonial Karachi","year":2022,"publisher":"Hurst & Co. / Oxford University Press","href":"https://www.hurstpublishers.com/book/insecure-guardians/","role":"Author","description":"Drawing on more than nineteen months of ethnographic fieldwork in Karachi, including interviews and participant observation inside police stations and training centres, this book examines how securitisation has shaped everyday policing in urban Pakistan. It traces how competing demands for security and stalled institutional reform have driven militarisation and a culture of procedural informality."},{"title":"Southern and Postcolonial Perspectives on Policing, Security and Social Order","year":2023,"publisher":"Bristol University Press","href":"https://bristoluniversitypress.co.uk/southern-and-postcolonial-perspectives-on-policing-security-and-social-order","role":"Co-editor, with Roxana P. Cavalcanti & Peter Squires","description":"An edited collection that broadens Southern Criminology by examining how postcolonial legacies continue to shape policing and security systems across the Global South, and how police overreach can undermine the very security it claims to provide."}]