{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/in-progress/layout,_N_T_/in-progress/page,_N_T_/in-progress"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/in-progress/__PAGE__",
    "/in-progress",
    "/_index",
    "/_head"
  ]
}